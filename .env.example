# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role Key (for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Admin Configuration (comma-separated list)
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# Mapbox Configuration (for environmental impact map)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_token_here

# Snippe.sh Payment Configuration
NEXT_PUBLIC_SNIPPESH_CONFIGURED=false
SNIPPESH_API_KEY=your_snippesh_api_key_here
SNIPPESH_WEBHOOK_SECRET=your_webhook_secret_here
